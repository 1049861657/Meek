# 复制为 .env 后按需修改（全仓库唯一配置源：Web / Worker / Prisma CLI 共用）

# Prisma 7 SQLite：路径相对项目根目录
DATABASE_URL="file:./packages/db/prisma/dev.db"

# T1 消息总线（BullMQ + ioredis）；缺 REDIS_URL 时 worker 进程启动 throw
# Redis key 前缀：meek（参考产品等价前缀 mcp-client）
REDIS_URL="redis://127.0.0.1:6379/0"

# Inbound Worker 并发数（可选，默认 5）
INBOUND_WORKER_CONCURRENCY=5

# T1-07 飞书渠道（未配置时不启动飞书 listener）
# FEISHU_APP_ID="cli_xxxxxxxx"
# FEISHU_APP_SECRET="xxxxxxxxxxxxxxxx"
# FEISHU_DOMAIN=lark

# T1-08 钉钉渠道（未配置时不启动钉钉 listener）
# DINGTALK_CLIENT_ID="dingxxxxxxxx"
# DINGTALK_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# T4 better-auth（用户账号 + Web 会话）
BETTER_AUTH_SECRET="change-me-please-32+chars-random"

# MCP roots 工作区（可选；`;` 或 `,` 分隔多个路径）
# MCP_CLIENT_ROOTS="D:/workspace/project-a;D:/workspace/project-b"

# P3-02-B 跨会话 Memory（Hindsight Cloud + TS SDK）
# HINDSIGHT_BASE_URL="https://api.hindsight.vectorize.io"
# HINDSIGHT_API_KEY="hsk_..."
